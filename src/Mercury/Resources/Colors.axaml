<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="SurfaceBrush" Color="#ffffff"></SolidColorBrush>
    <SolidColorBrush x:Key="OutlineBrush" Color="#d8d8d8"></SolidColorBrush>
    <SolidColorBrush x:Key="HoverBrush" Color="#dadadf"></SolidColorBrush>
    <SolidColorBrush x:Key="SelectedBrush" Color="#3573f0"></SolidColorBrush>
    <SolidColorBrush x:Key="TextBrush" Color="#0f0f0f"></SolidColorBrush>
</ResourceDictionary>
