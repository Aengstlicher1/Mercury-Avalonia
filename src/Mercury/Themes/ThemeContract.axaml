<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowSurfaceColor">#ffffff</Color>
    <Color x:Key="SurfaceColor">#ffffff</Color>
    <Color x:Key="SurfaceHighlightColor">#ffffff</Color>
    <Color x:Key="SubSurfaceColor">#ffffff</Color>
    <Color x:Key="SurfaceItemColor">#ffffff</Color>
    <Color x:Key="OutlineColor">#ffffff</Color>
    <Color x:Key="OutlineHighlightColor">#ffffff</Color>
    <Color x:Key="HoverColor">#ffffff</Color>
    <Color x:Key="PressedColor">#ffffff</Color>
    <Color x:Key="SelectedColor">#ffffff</Color>
    <Color x:Key="TextColor">#ffffff</Color>
    <Color x:Key="SubTextColor">#ffffff</Color>
    
    <SolidColorBrush x:Key="WindowSurfaceBrush" Color="{StaticResource WindowSurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHighlightBrush" Color="{StaticResource SurfaceHighlightColor}"/>
    <SolidColorBrush x:Key="SubSurfaceBrush" Color="{StaticResource SubSurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceItemBrush" Color="{StaticResource SurfaceItemColor}"/>
    <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource OutlineColor}"/>
    <SolidColorBrush x:Key="OutlineHighlightBrush" Color="{StaticResource OutlineHighlightColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="PressedBrush" Color="{StaticResource PressedColor}"/>
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubTextBrush" Color="{StaticResource SubTextColor}"/>
    
    
    <CornerRadius x:Key="CornerRadius">8</CornerRadius>
</ResourceDictionary>
