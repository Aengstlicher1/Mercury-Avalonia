<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mercury.ViewModels"
        xmlns:views="using:Mercury.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ico="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:models="clr-namespace:Mercury.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Mercury.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="48"
        Background="{StaticResource WindowSurfaceBrush}"
        TransparencyLevelHint="AcrylicBlur, Mica, Transparent"
        Width="950"
        Height="500"
        Title="Mercury">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Panel>
        <Panel IsHitTestVisible="False">
            <!-- White base -->
            <Border Background="{StaticResource WindowSurfaceBrush}"/>
    
            <!-- 50% image on top -->
            <Border>
                <Border.Background>
                    <ImageBrush Source="{Binding CurrentBackgroundImage}" Stretch="UniformToFill" Opacity="0.1"/>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="80"/>
                </Border.Effect>
            </Border>
        </Panel>
        
        <Grid Name="RootGrid" RowDefinitions="64, *" ColumnDefinitions="*, *, *">
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                <Grid ColumnDefinitions="*, *" Margin="60,0,120,0">
                    <Grid Grid.Column="0">
                        <ItemsControl
                            VerticalAlignment="Top"
                            Margin="8,12,0,0"
                            ItemsSource="{Binding PageInfos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:PageInfo">
                                    <Button 
                                        Margin="4,0" 
                                        Padding="8" 
                                        Background="Transparent"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateToCommand}"
                                        CommandParameter="{Binding }">
                                        <Grid RowDefinitions="*, Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Name}" />
                                            <Border Grid.Row="1" Height="3" CornerRadius="8"
                                                    Classes.selected="{Binding IsSelected}">
                                                <Border.Styles>
                                                    <Style Selector="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Style>
                                                    <Style Selector="Border.selected">
                                                        <Setter Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                                    </Style>
                                                </Border.Styles>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    <Grid Grid.Column="2" 
                          ColumnDefinitions="*, Auto, Auto" 
                          VerticalAlignment="Top"
                          Margin="0,12,0,0"
                          WindowDecorationProperties.ElementRole="User">
                        <TextBox Grid.Column="0" PlaceholderText="Search for Songs, Albums, Playlists"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 CornerRadius="8,0,0,8" 
                                 WindowDecorationProperties.ElementRole="User"/>
                        <Border Grid.Column="1" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="0,0,1,0" />
                        <ComboBox Grid.Column="2" CornerRadius="0,8,8,0"
                                  ItemsSource="{Binding SearchFilters}"
                                  SelectedItem="{Binding SelectedSearchFilter}"
                                  WindowDecorationProperties.ElementRole="User"/>
                    </Grid>
                </Grid>
            </Border>
            
            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" ColumnDefinitions="42, *" RowDefinitions="*, Auto">
                <Border Grid.Row="0" Grid.Column="1" 
                        CornerRadius="8" 
                        Margin="0,0,6,3">
                    <NavigationPage Name="Navigator" BarHeight="0">
                        <NavigationPage.PageTransition>
                            <PageSlide Duration="00:00:00.100" Orientation="Horizontal">
                                
                            </PageSlide>
                        </NavigationPage.PageTransition>
                    </NavigationPage>
                </Border>
                
                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                      ColumnDefinitions="*, 3*">
                    <Border Grid.Column="0" Height="72" 
                            Background="{StaticResource SurfaceBrush}"
                            Margin="0,3,12,0"
                            CornerRadius="0,8,0,0">
                        <Grid ColumnDefinitions="*, 1.5*, *">
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border CornerRadius="12"
                                        Width="64" Height="64"
                                        Margin="8"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource OutlineBrush}">
                                    <Border
                                        CornerRadius="12">
                                        <Border.Background>
                                            <ImageBrush Source="{Binding CurrentTrackImage}"/>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource TextBrush}" 
                                               Text="{Binding CurrentTrack.Title}"
                                               TextWrapping="NoWrap">
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource TextBrush}" 
                                               Text="{Binding CurrentTrack.Artists}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="1"
                            Background="{StaticResource SurfaceBrush}"
                            Margin="12,3,0,0"
                            CornerRadius="8,0,0,0">
                        
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Panel>
</Window>
