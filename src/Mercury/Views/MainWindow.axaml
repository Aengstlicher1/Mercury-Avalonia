<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icon="clr-namespace:IconPacks.Avalonia.MaterialDesign;assembly=IconPacks.Avalonia.MaterialDesign"
        xmlns:imageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:models="clr-namespace:Mercury.Models"
        xmlns:vm="clr-namespace:Mercury.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Mercury.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="48"
        Background="{StaticResource WindowSurfaceBrush}"
        Width="950"
        Height="500"
        Title="Mercury">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Panel>
        <Panel IsHitTestVisible="False">
            <!-- WindowBrush base -->
            <Border Background="{DynamicResource WindowSurfaceBrush}"/>
    
            <!-- 4% image on top -->
            <Border>
                <Border.Background>
                    <ImageBrush Source="{Binding CurrentBackgroundImage}" Stretch="UniformToFill" Opacity="0.04"/>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="80"/>
                </Border.Effect>
            </Border>
        </Panel>
        
        <Grid Name="RootGrid" RowDefinitions="48, *">
            <Border Grid.Row="0">
                <Grid ColumnDefinitions="48, Auto, Auto, *, Auto, 120">
                    <Button Grid.Column="0"
                            Classes="Ghost"
                            Width="{Binding $self.Bounds.Height}"
                            Command="{Binding NavigationService.GoBackCommand}"
                            IsVisible="{Binding NavigationService.CanGoBack}"
                            HorizontalAlignment="Center"
                            Content="{icon:MaterialDesign Kind=ArrowBackRound, Width=16}"/>
                    <Grid Grid.Column="1">
                        <Border Classes="Decor"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Margin="6">
                            <ItemsControl
                                ItemsSource="{Binding NavigationService.Tabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:PageDescriptor">
                                        <Button 
                                            Classes="Ghost"
                                            IsVisible="{Binding IsTab}"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateToCommand}"
                                            CommandParameter="{Binding }">
                                            <TextBlock Text="{Binding Title}"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                    <Grid Grid.Column="2"
                          ColumnDefinitions="*, Auto" 
                          VerticalAlignment="Stretch"
                          Margin="6">
                        <TextBox Grid.Column="0" PlaceholderText="Search for Songs, Albums, Playlists"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 CornerRadius="{DynamicResource LeftCornerRadius}"
                                 Margin="0,0,-2,0"
                                 VerticalAlignment="Stretch"
                                 GotFocus="SearchBox_GotFocus"
                                 WindowDecorationProperties.ElementRole="User"/>
                        <ComboBox Grid.Column="1" CornerRadius="{DynamicResource RightCornerRadius}"
                                  ItemsSource="{Binding SearchFilters}"
                                  SelectedItem="{Binding SearchFilter}"
                                  WindowDecorationProperties.ElementRole="User"/>
                    </Grid>
                    
                    <Border Grid.Column="1" Grid.ColumnSpan="3" Margin="12,4,12,0"
                            Height="1" BorderBrush="{DynamicResource OutlineBrush}"
                            BorderThickness="1" VerticalAlignment="Bottom"/>
                    <Button Grid.Column="4" Classes="Round" Margin="6"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource OutlineBrush}"
                            Command="{Binding NavigateToAccountsCommand}">
                        <icon:PackIconMaterialDesign Kind="PersonOutlineOutline"/>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Hud for displaying current playing and music controls -->
            <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="42, *, 42" RowDefinitions="*, Auto">
                <Border Grid.Row="0" Grid.Column="1"
                        CornerRadius="8"
                        Margin="0,0,6,3">
                    <TransitioningContentControl Name="Navigator" />
                </Border>
                
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                        Height="76"
                        Background="{DynamicResource SurfaceBrush}">
                    <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">
                        <!-- Top track position display -->
                        <Slider Grid.Column="0" Grid.ColumnSpan="5" 
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding CurrentTrackPosition, Mode=TwoWay}"
                                IsEnabled="{Binding CurrentTrack, Converter={StaticResource NotNullConverter}}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                Margin="0,-8,0,0"/>
                        
                        <!-- Left music controls -->
                        <Grid Grid.Column="0" Margin="16,4,4,4">
                            <StackPanel VerticalAlignment="Stretch" Orientation="Horizontal">
                                <!-- Skip back -->
                                <Button Classes="Round"
                                        Content="{icon:MaterialDesign Kind=SkipPreviousRound, Width=22, Height=22}"
                                        Command="{Binding SkipBackCommand}"/>
                                
                                <!-- Toggle Playback -->
                                <Button Classes="Round"
                                        Command="{Binding TogglePlayCommand}">
                                    <icon:PackIconMaterialDesign Width="32" Height="32"
                                        Kind="{Binding IsPlaying, Converter={StaticResource PlayIconConverter}}"/>
                                </Button>
                                
                                <!-- Skip forward -->
                                <Button Classes="Round"
                                        Content="{icon:MaterialDesign Kind=SkipNextRound, Width=22, Height=22}"
                                        Command="{Binding SkipForwardCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Middle track display -->
                        <Grid Grid.Column="2" Margin="12" ColumnDefinitions="Auto, Auto"
                              IsVisible="{Binding CurrentTrack, Converter={StaticResource NotNullConverter}}">
                            <!-- Thumbnail -->
                            <Border Grid.Column="0" 
                                    CornerRadius="8"
                                    Width="{Binding $self.Bounds.Height}">
                                <Border.Background>
                                    <ImageBrush Stretch="UniformToFill" imageLoader:ImageBrushLoader.Source="{Binding CurrentTrack.Thumbnails.LowestRes.Url}"/>
                                </Border.Background>
                            </Border>
                            
                            <!-- Thumbnail overlay -->
                            <Button Grid.Column="0" 
                                    Command="{Binding EnterPlayingCommand}"
                                    Width="{Binding $self.Bounds.Height}"
                                    Classes="Ghost"
                                    Padding="0">
                                <icon:PackIconMaterialDesign Kind="FullscreenRound" Height="24" Width="24"
                                                             IsVisible="False"/>
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="ContentTemplate">
                                            <DataTemplate>
                                                <icon:PackIconMaterialDesign Kind="FullscreenRound" Height="24" Width="24"/>
                                            </DataTemplate>
                                        </Setter>
                                    </Style>
                                </Button.Styles>
                            </Button>
                            
                            <!-- Title and artist for the current Track -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CurrentTrack.Title}"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="16"/>
                                <Button Content="{Binding CurrentTrack.Artist.Name}"
                                        Classes="Link"
                                        Foreground="{DynamicResource SubTextBrush}"
                                        FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Right music controls -->
                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    Margin="4,4,16,4"
                                    Spacing="8">
                            <Button Classes="Round"
                                    ToolTip.Tip="{Binding RepeatState}"
                                    Command="{Binding SwitchRepeatStateCommand}">
                                <icon:PackIconMaterialDesign Width="16" Height="16"
                                                             Kind="{Binding RepeatState, Converter={StaticResource RepeatIconConverter}}"/>
                            </Button>
                            <Button Classes="Round" ToolTip.Tip="{Binding Volume, StringFormat={}{0:F0} %}">
                                <icon:PackIconMaterialDesign Width="16" Height="16"
                                                             Kind="{Binding Volume, Converter={StaticResource VolumeIconConverter}}"/>
                            </Button>
                            <Slider Value="{Binding Volume, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Width="120"
                                    Minimum="0"
                                    Maximum="100"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Panel>
    
</Window>
