<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mercury.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icon="clr-namespace:IconPacks.Avalonia.MaterialDesign;assembly=IconPacks.Avalonia.MaterialDesign"
        xmlns:imageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:models="clr-namespace:Mercury.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Mercury.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="48"
        Background="{StaticResource WindowSurfaceBrush}"
        TransparencyLevelHint="AcrylicBlur, Mica, Transparent"
        Width="950"
        Height="500"
        Title="Mercury">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Panel>
        <Panel IsHitTestVisible="False">
            <!-- WindowBrush base -->
            <Border Background="{DynamicResource WindowSurfaceBrush}"/>
    
            <!-- 10% image on top -->
            <Border>
                <Border.Background>
                    <ImageBrush Source="{Binding CurrentBackgroundImage}" Stretch="UniformToFill" Opacity="0.1"/>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="80"/>
                </Border.Effect>
            </Border>
        </Panel>
        
        <Grid Name="RootGrid"
              RowDefinitions="64, *">
            <Border Grid.Row="0" Grid.Column="0">
                <Grid ColumnDefinitions="*, *, 96" Margin="60,0,60,0">
                    <Grid Grid.Column="0">
                        <ItemsControl
                            VerticalAlignment="Top"
                            Margin="8,12,0,0"
                            ItemsSource="{Binding PageInfos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:PageInfo">
                                    <Button 
                                        Margin="4,0" 
                                        Padding="8" 
                                        Background="Transparent"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateToCommand}"
                                        CommandParameter="{Binding }">
                                        <Grid RowDefinitions="*, Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Name}" />
                                            <Border Grid.Row="1" Height="3" CornerRadius="8"
                                                    Classes.selected="{Binding IsSelected}">
                                                <Border.Styles>
                                                    <Style Selector="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Style>
                                                    <Style Selector="Border.selected">
                                                        <Setter Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                                    </Style>
                                                </Border.Styles>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    <Grid Grid.Column="1"
                          ColumnDefinitions="*, Auto, Auto" 
                          VerticalAlignment="Top"
                          Margin="0,12,0,0">
                        <TextBox Grid.Column="0" PlaceholderText="Search for Songs, Albums, Playlists"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 CornerRadius="8,0,0,8" 
                                 GotFocus="SearchBox_GotFocus"
                                 WindowDecorationProperties.ElementRole="User"/>
                        <Border Grid.Column="1" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="0,0,1,0" />
                        <ComboBox Grid.Column="2" CornerRadius="0,8,8,0"
                                  ItemsSource="{Binding SearchFilters}"
                                  SelectedItem="{Binding SearchFilter}"
                                  WindowDecorationProperties.ElementRole="User"/>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Hud for displaying current playing and music controls -->
            <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="42, *, 42" RowDefinitions="*, Auto">
                <Border Grid.Row="0" Grid.Column="1"
                        CornerRadius="8"
                        Margin="0,0,6,3">
                    <NavigationPage Name="Navigator" BarHeight="0"/>
                </Border>
                
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                        Height="76"
                        Background="{DynamicResource SurfaceBrush}">
                    <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">
                        <!-- Top track position display -->
                        <Slider Grid.Column="0" Grid.ColumnSpan="5" 
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding CurrentTrackPosition, Mode=TwoWay}"
                                IsEnabled="{Binding CurrentTrack, Converter={StaticResource NotNullConverter}}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                Margin="0,-8,0,0"/>
                        
                        <!-- Left music controls -->
                        <Grid Grid.Column="0" Margin="16,4,4,4">
                            <StackPanel VerticalAlignment="Stretch" Orientation="Horizontal">
                                <!-- Skip back -->
                                <Button CornerRadius="64"
                                        Content="{icon:MaterialDesign Kind=SkipPreviousRound, Width=22, Height=22}"
                                        Command="{Binding SkipBackCommand}"/>
                                
                                <!-- Toggle Playback -->
                                <Button CornerRadius="64"
                                        HotKey="Space"
                                        Command="{Binding TogglePlayCommand}">
                                    <icon:PackIconMaterialDesign Width="32" Height="32"
                                        Kind="{Binding IsPlaying, Converter={StaticResource PlayIconConverter}}"/>
                                </Button>
                                
                                <!-- Skip forward -->
                                <Button CornerRadius="64"
                                        Content="{icon:MaterialDesign Kind=SkipNextRound, Width=22, Height=22}"
                                        Command="{Binding SkipForwardCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Middle track display -->
                        <Grid Grid.Column="2" Margin="12" ColumnDefinitions="Auto, Auto">
                            <!-- Thumbnail -->
                            <Border Grid.Column="0" 
                                    CornerRadius="8"
                                    Width="{Binding $self.Bounds.Height}">
                                <Border.Background>
                                    <ImageBrush Stretch="UniformToFill" imageLoader:ImageBrushLoader.Source="{Binding CurrentTrack.Thumbnails.LowestRes.Url}"/>
                                </Border.Background>
                            </Border>
                            
                            <!-- Thumbnail overlay -->
                            <Button Grid.Column="0" 
                                    Width="{Binding $self.Bounds.Height}"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="0">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="ContentTemplate">
                                            <DataTemplate>
                                                <icon:PackIconMaterialDesign Kind="FullscreenRound" Height="24" Width="24"/>
                                            </DataTemplate>
                                        </Setter>
                                    </Style>
                                </Button.Styles>
                            </Button>
                            
                            <!-- Title and artist for the current Track -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CurrentTrack.Title}"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="16"/>
                                <TextBlock Text="{Binding CurrentTrack.Artist}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Right music controls -->
                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    Margin="4,4,16,4"
                                    Spacing="8">
                            <Button Command="{Binding SwitchRepeatStateCommand}">
                                <icon:PackIconMaterialDesign Width="16" Height="16"
                                                             Kind="{Binding RepeatState, Converter={StaticResource RepeatIconConverter}}"/>
                            </Button>
                            <icon:PackIconMaterialDesign Width="16" Height="16"
                                                         Kind="{Binding Volume, Converter={StaticResource VolumeIconConverter}}"/>
                            <Slider Value="{Binding Volume, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    Width="120"
                                    Minimum="0"
                                    Maximum="100"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Panel>
    
</Window>
